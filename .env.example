# Default provider — one of: openai, anthropic, gemini, ollama
DEFAULT_PROVIDER=gemini

# Provider API keys — only set the one you use
OPENAI_API_KEY=
OPENAI_MODEL_NAME=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NAME=
GEMINI_API_KEY=
GEMINI_MODEL_Name=
OLLAMA_BASE_URL=http://localhost:11434

# Infrastructure — injected by Railway plugins
DATABASE_URL=postgresql://user:pass@localhost:5432/aibackend
REDIS_URL=redis://localhost:6379/0

# Auth — leave empty to disable auth in dev
API_KEYS=

# Webhooks
WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_SECONDS=10

# Caching
RESULT_CACHE_TTL_SECONDS=3600

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
