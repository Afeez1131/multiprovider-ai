DEFAULT_PROVIDER=gemini

# Provider API keys — only set the ones you use
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NAME=claude-haiku-4-5
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash
OLLAMA_BASE_URL=http://localhost:11434

# Infrastructure — injected by Railway plugins
DATABASE_URL=postgresql://user:pass@localhost:5432/aibackend
REDIS_URL=redis://localhost:6379/0

# Auth — leave empty to disable auth in dev
API_KEYS=

# Webhooks
WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_SECONDS=10

# Caching
RESULT_CACHE_TTL_SECONDS=3600

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
